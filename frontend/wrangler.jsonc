{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "glow-with-lucy",
  "compatibility_date": "2026-04-04",
  "pages_build_output_dir": "build",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "glow-with-lucy",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ]
}
